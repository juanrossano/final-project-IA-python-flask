{
    "editor.formatOnSave": true,
    "editor.rulers": [
        79
    ],
    "editor.trimTrailingWhitespace": true,
    "files.insertFinalNewline": true,
    "files.exclude": {
        "**/__pycache__": true,
        "**/.pytest_cache": true,
        "**/.ruff_cache": true
    },
    "python.analysis.typeCheckingMode": "basic",
    "terminal.integrated.hideOnStartup": "always"
}